# Application
APP_ENV=development
APP_NAME=onboarding-chatbot
APP_VERSION=0.1.0
LOG_LEVEL=INFO
LOG_FORMAT=json

# API
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://onboarding:onboarding@postgres:5432/onboarding
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# Session
SESSION_TTL_SECONDS=86400
SESSION_ABANDON_AFTER_DAYS=7

# LLM (placeholder for Phase 5)
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-5
LLM_TIMEOUT_SECONDS=15

# Optimization backend (placeholder for Phase 7)
OPTIMIZATION_BACKEND_URL=http://optimizer:9000
OPTIMIZATION_BACKEND_TIMEOUT_SECONDS=30